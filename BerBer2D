<!DOCTYPE html>
<script>
const sessions = [
        { id: "val-06pm", time: 18, result: "13" },
        { id: "val-08pm", time: 20, result: "--" },
        { id: "val-09pm", time: 21, result: "--" },
        { id: "val-10pm", time: 22, result: "--" },
        { id: "val-11pm", time: 23, result: "--" }
    ];

    function updateDisplay() {
        const now = new Date();
        const clockEl = document.getElementById("live-clock");
        
        if (clockEl) {
            clockEl.innerText = now.toLocaleTimeString('en-US', { hour12: true });
        }

        const currentHour = now.getHours();
        const mainEl = document.getElementById("main-live-result");

        sessions.forEach(s => {
            const el = document.getElementById(s.id);
            if (el && currentHour >= s.time) {
                el.innerText = s.result;
            }
            if (mainEl && currentHour === s.time) {
                mainEl.innerText = s.result;
            }
        });
    }

    setInterval(updateDisplay, 1000);
    updateDisplay();
